# ─── TEMPLATE PARA VARIÁVEIS DE AMBIENTE DO VERCEL ─────────────────
#
# Como usar:
#   1. Copie este arquivo para .env.vercel.local (NÃO É commitado)
#      cp scripts/.env.vercel.example scripts/.env.vercel.local
#
#   2. Edite .env.vercel.local com os valores reais
#
#   3. Rode: bash scripts/setup-vercel-envs.sh
#
# Linhas vazias e comentários são ignorados.
# ───────────────────────────────────────────────────────────────────

# ─── Supabase (obrigatório) ────────────────────────────
# Pegue em: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Robô de cotação ───────────────────────────────────
COTACAO_ROBO_URL=http://177.7.38.7:3001
# Se você setou ROBO_TOKEN no .env do robô, coloque o mesmo valor aqui.
COTACAO_ROBO_TOKEN=

# ─── Porto Seguro (integração) ─────────────────────────
PORTO_LOGIN=
PORTO_SENHA=
PORTO_SUSEP=J8FXUJ

# ─── GoTo Connect (telefone) — opcional ────────────────
GOTO_CLIENT_ID=
GOTO_CLIENT_SECRET=
GOTO_REDIRECT_URI=

# ─── App URL ───────────────────────────────────────────
# URL pública do app — usada em redirects, etc.
NEXT_PUBLIC_APP_URL=https://cmsegcrm.vercel.app
