# Renomeie este arquivo para .env e preencha as credenciais.
# Nunca commite o .env real (já está no .gitignore).

# Credenciais Aggilizador
AGGILIZADOR_URL=https://aggilizador.com.br
AGGILIZADOR_EMAIL=bruno@cmseguros.com.br
AGGILIZADOR_SENHA=

# Configuração do servidor
PORT=3001
HOST=0.0.0.0

# Token de autenticação (opcional). Se setar, o CRM precisa enviar
# header `x-robo-token: <valor>` em cada request. Recomendado em produção.
ROBO_TOKEN=

# Modo de execução do browser
HEADLESS=true             # false → mostra a janela (debug local)
SLOW_MO=0                 # ms entre ações (debug visual). 0 = rápido
KEEP_BROWSER_OPEN=true    # true → reusa browser entre cotações (mais rápido)

# Timeouts (ms)
TIMEOUT_NAV=60000
TIMEOUT_FIELD=15000

# Diretório de logs e screenshots de erro
LOG_DIR=./logs

# Supabase (service role) — usado pelo /cotacao-async pra escrever o resultado
# direto no banco quando a cotação completa termina (~2-3 min), evitando
# timeout do Vercel Hobby. Pegue em Supabase → Project Settings → API.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
